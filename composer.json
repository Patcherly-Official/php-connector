{
    "name": "patcherly/php-connector",
    "description": "Patcherly detects bugs in real time in your app.  It creates a customized AI patch, and once you approve it, backs up your code, fixes it & tests the patch for you. If anything is off, it rolls back the changes automatically, or you can always roll it back in a click. Website: https://patcherly.com · Docs: https://help.patcherly.com/connectors/php/",
    "type": "library",
    "license": "MIT",
    "homepage": "https://patcherly.com",
    "support": {
        "docs": "https://help.patcherly.com/connectors/php/",
        "issues": "https://github.com/Patcherly-Official/patcherly-connector-packages/issues",
        "source": "https://github.com/Patcherly-Official/php-connector"
    },
    "require": {
        "php": ">=7.4",
        "ext-json": "*",
        "ext-curl": "*"
    },
    "bin": [
        "bin/patcherly"
    ],
    "autoload": {
        "classmap": [
            "php_agent.php",
            "oauth_client.php",
            "credential_store.php",
            "sanitizer.php",
            "context_collector.php",
            "backup_manager.php",
            "patch_applicator.php",
            "queue_manager.php"
        ],
        "files": [
            "connector_version.php",
            "lib/api_paths.php",
            "lib/ingest_severity.php"
        ]
    }
}
